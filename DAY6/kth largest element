class Solution {
    public int findKthLargest(int[] nums, int k) {

        Queue<Integer> minHeap = new PriorityQueue<>();

        for (int x : nums) {
            minHeap.add(x);
        }

        int n = nums.length;

        for (int j = 0; j < n - k; j++) {
            minHeap.remove();
        }

        return minHeap.peek();
    }
}