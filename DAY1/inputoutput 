//switch case
public class Main {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        int days = sc.nextInt();

        switch(days) {
            case 1:
                System.out.println("Monday");
                break;

            case 2:
                System.out.println("Tuesday");
                break;

            default:
                System.out.println("Invalid Day");
        }

        sc.close();
    }
}
//for loop
public class Main{
    public static void main(String [] args ){
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int sum =0;
        for(int i=1;i<n;i++){
            sum+=i;

        } 
        System.out.println(sum);
        sc.close();

    }
}
// Java is always pass-by-value. For primitive types, a copy of the actual value is passed. For objects, a copy of the reference (address) is passed. Therefore, object contents can be modified inside methods, but the reference itself cannot be changed for the caller.

// One-Line Trick to Remember
// Primitive → Copy of data
// Object → Copy of address
// Java → Always Pass By Value ✅

class Demo{
    public static void main(String [] args){
        int a = 1000;
        System.out.print(a); //1000
        int b;
        b=a;
        System.out.print(b); //1000
        b=2000;
        System.out.print(b);//2000
        System.out.print(a); //1000
        
    }
}
